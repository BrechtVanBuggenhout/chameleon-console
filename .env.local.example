# Console access password. Leave unset to open the console to anyone (local dev).
# Set this when deploying to a public URL.
CONSOLE_PASSWORD=changeme

# Key Vault API — leave unset to use static fixtures (safe for local dev).
# When set, pages will fetch live data from the Key Vault instead of fixtures.
VAULT_BASE_URL=https://chameleon-key-vault-prod-eeazinghka-uc.a.run.app

# Key Vault's app-level shared secret (its VAULT_API_KEY value — see
# main.ts's auth hook, which checks x-api-key OR this as a Bearer token).
# Not a Cloud Run/OIDC identity token, despite what this var name suggests.
VAULT_API_TOKEN=

# Shared secret gating the PII registry declare API (POST/PUT/DELETE
# /pii-registry/resources) — must match Key Vault's PII_REGISTRY_WRITE_TOKEN.
VAULT_REGISTRY_WRITE_TOKEN=
